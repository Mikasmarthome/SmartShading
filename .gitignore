__pycache__/
*.py[cod]
*$py.class

# Test / type / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Virtual environments / local env
.venv/
venv/
env/
.env

# Build / packaging artifacts
dist/
build/
*.egg-info/

# Logs / temporary / dump files
*.log
*.tmp
*.bak

# OS-specific
.DS_Store
Thumbs.db

# IDE / editor
.idea/
.vscode/
*.swp
*~

# Internal research material — must NOT be published.
# external_analysis/ holds full copies of unrelated third-party projects kept
# only for local study; it is third-party code and out of scope for this repo.
external_analysis/
*.zip

# Internal working / audit / research documents — kept locally, not part of the
# public release. The published package is the integration plus README/LICENSE/
# hacs.json (see RELEASE_PREP_AUDIT.md for the release allowlist).
docs/
ARCHITECTURE.md
*_AUDIT.md
TODO.md
RELEASE_NOTES*.md

# Local-only development assets — kept locally, excluded from the public release
# scope. Tests and scripts remain in the working tree and still run locally; they
# are simply not part of the published repository.
#
# Published brand assets live in two locations (both intentionally NOT ignored):
#   brand/                                — top-level, for HACS/GitHub display
#   custom_components/smartshading/brand/ — internal, served by HA Core locally
# Brand SOURCE images are kept entirely outside the repository; only the derived
# brand/{icon,logo}.png artefacts are ever published.
tests/
scripts/
